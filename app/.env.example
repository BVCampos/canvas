# Create your own Supabase project, then run every migration in supabase/migrations/ in order.
# Canvas is standalone — own project, own auth, own workspaces. See ADR-0004.
# Canvas tables live in public with the canvas_* prefix (see supabase/migrations/0001_canvas_schema.sql);
# tenancy tables (workspaces, users, workspace_memberships, workspace_invites) sit in public
# without a prefix (see supabase/migrations/0000_workspace_foundation.sql).
# Dashboard: https://supabase.com/dashboard/project/<your-project-ref>

# Public — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only secret. Never expose to the browser. Never commit.
# Used for: HTML deck parser (uploads assets via service role), MCP token revocation,
# workspace-create server action (RLS blocks direct INSERT on public.workspaces).
SUPABASE_SECRET_KEY=sb_secret_...

# Server-only 32-byte base64 key used to encrypt personal OpenRouter API keys.
# Generate once with: openssl rand -base64 32
# Keep it stable across deploys; changing it makes existing saved keys unreadable.
CANVAS_CREDENTIAL_ENCRYPTION_KEY=

# App base URL — used in absolute redirects (email confirmation, MCP install deeplink).
NEXT_PUBLIC_APP_URL=http://localhost:3001
